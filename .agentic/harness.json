{
  "projectName": "Harness",
  "stackTags": [
    "Bash scripts plus Node.js (ES Modules) for CLI and scaffold generation; uses standard Unix tools such as `sed`, `cp`, `ln`, and `python3`.",
    "Not a classic frontend/backend product; repository for CLI bootstrap, template rendering, hook/policy generation, and skill/instruction scaffolding.",
    "No application database and no ORM."
  ],
  "protectedExactPaths": [
    ".env",
    ".env.local"
  ],
  "protectedPrefixes": [],
  "protectedExistingPrefixes": [],
  "protectedRegexes": [
    "^\\.env\\..+",
    "^\\.env\\.[^/]*$"
  ],
  "deniedCommandRegexes": [
    "^git push( .*)?$",
    "^rm -rf( .*)?$",
    "^bash install\\.sh( .*)?$"
  ],
  "toolingPreferences": {
    "debugging": {
      "skill": "systematic-debugging",
      "repoLocalSkillPath": ".agents/skills/systematic-debugging",
      "requiredForBugs": true,
      "requiredForUnexpectedBehavior": true,
      "requiredForFailingTests": true
    },
    "completion": {
      "skill": "verification-before-completion",
      "repoLocalSkillPath": ".agents/skills/verification-before-completion",
      "requiredBeforeSuccessClaims": true,
      "verificationPolicy": "fresh-smallest-credible-command"
    },
    "review": {
      "skill": "requesting-code-review",
      "repoLocalSkillPath": ".agents/skills/requesting-code-review",
      "primaryAgent": "project-reviewer",
      "securityAgent": "security-review",
      "requiredForNonTrivialChanges": true,
      "requiredForHighRiskChanges": true
    }
  },
  "postEditCommands": [
    "bash -n install.sh bin/agentic-project-init templates/test-harness.sh",
    "node --check bin/apply-project-agentic-init.mjs",
    "bash install.sh --help >/dev/null",
    "./bin/agentic-project-init --help >/dev/null"
  ],
  "stopCommands": [
    "bash -n install.sh bin/agentic-project-init templates/test-harness.sh",
    "node --check bin/apply-project-agentic-init.mjs",
    "tmpdir=\"$(mktemp -d)\" && trap 'rm -rf \"$tmpdir\"' EXIT && ./bin/agentic-project-init \"$tmpdir\" --force >/dev/null && node bin/apply-project-agentic-init.mjs \"$tmpdir\" >/dev/null && bash \"$tmpdir/test-harness.sh\""
  ]
}
